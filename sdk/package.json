{
  "name": "curtain",
  "version": "0.1.0",
  "description": "JavaScript/TypeScript client for Curtain — self-hosted BaaS made in India",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev":   "tsup src/index.ts --format cjs,esm --dts --watch",
    "test":  "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "tsup":            "^8.0.0",
    "typescript":      "^5.3.0",
    "@types/node":     "^20.0.0",
    "vitest":          "^1.6.0",
    "@vitest/coverage-v8": "^1.6.0",
    "jsdom":           "^24.0.0",
    "@vitest/ui":      "^1.6.0"
  },
  "keywords": ["supabase", "baas", "india", "self-hosted", "postgres"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/curtain/curtain"
  }
}
