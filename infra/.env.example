# =============================================================================
# Curtain Environment Variables
# Copy to .env and fill in required values before running docker compose up.
# NEVER commit .env to git.
# =============================================================================

# ── Required ──────────────────────────────────────────────────────────────────

# Your domain (must have DNS pointing to this server)
DOMAIN=baas.example.com

# PostgreSQL password (use a strong random string: openssl rand -hex 32)
POSTGRES_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# JWT secret (minimum 32 chars: openssl rand -hex 32)
JWT_SECRET=CHANGE_THIS_JWT_SECRET_MIN_32_CHARS

# MinIO admin password (use a strong random string)
MINIO_ROOT_PASSWORD=CHANGE_THIS_MINIO_PASSWORD

# ── Optional ──────────────────────────────────────────────────────────────────

# PostgreSQL DB name and user (defaults are fine)
POSTGRES_DB=curtain
POSTGRES_USER=curtain

# MinIO admin user (default: minio)
MINIO_ROOT_USER=minio

# Admin email for Let's Encrypt TLS cert notifications
ADMIN_EMAIL=admin@example.com

# Google OAuth (leave empty to disable Google sign-in)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
