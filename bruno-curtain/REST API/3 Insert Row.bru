meta {
  name: Insert Row (PostgREST)
  type: http
  seq: 3
}

post {
  url: {{base_url}}/rest/v1/products
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
  Accept-Profile: public
  Content-Profile: public
  Prefer: return=representation
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "name": "Widget",
    "price": 499,
    "description": "A nice widget",
    "active": true
  }
}
