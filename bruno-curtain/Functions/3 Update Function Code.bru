meta {
  name: Update Function Code
  type: http
  seq: 3
}

put {
  url: {{base_url}}/functions/v1/functions/REPLACE_WITH_FUNCTION_ID
  body: json
  auth: bearer
}

headers {
  Content-Type: application/json
}

